# Server configuration — copy to `.env` and fill in.
#
# On Vercel: do NOT commit a .env; set these in the project's
#   Settings -> Environment Variables (the dashboard), not a file.
# Locally: copy this to `.env` and run:  uv run --env-file .env main.py
#   (plain `uv run main.py` does NOT auto-read .env).

# --- Database ---------------------------------------------------------------
# Leave UNSET locally to use SQLite (./payouts.db).
# In production set a Postgres connection string (Vercel Postgres / Neon):
#   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_naGL7bhqNgW8@ep-billowing-haze-au14t5o3.c-10.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Auth -------------------------------------------------------------------
# REQUIRED in production: a long random string used to sign login tokens.
# If unset, the code falls back to an insecure dev default.
AUTH_SECRET=samplesecrete89527938
# Optional: token lifetime in seconds (default 86400 = 24h).
AUTH_TOKEN_TTL=86400

# --- CORS -------------------------------------------------------------------
# Comma-separated allowed origins for the browser client.
# Unset = allow all ("*"). In production set your client URL:
#   https://your-client.vercel.app
CORS_ORIGINS=faym-dashboard-ol3a70743-rr-vcl-t1.vercel.app

# --- Seeded accounts (created on first startup) -----------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
USER_USERNAME=user
USER_PASSWORD=user123
